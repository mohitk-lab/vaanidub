# VaaniDub Environment Configuration

# ── Required ──
HF_TOKEN=hf_your_huggingface_token_here          # For pyannote + IndicF5 (gated models)

# ── Database ──
DATABASE_URL=sqlite:///./data/vaanidub.db         # SQLite for local, postgresql://user:pass@host/db for production

# ── Redis (required for API/worker mode) ──
REDIS_URL=redis://localhost:6379/0

# ── Paid API Fallbacks (optional) ──
OPENAI_API_KEY=                                    # For Whisper API fallback
ELEVENLABS_API_KEY=                                # For ElevenLabs TTS fallback
GOOGLE_TRANSLATE_API_KEY=                          # For Google Translate fallback

# ── Storage ──
STORAGE_BASE_PATH=./data/jobs
STORAGE_TEMP_PATH=./data/tmp

# ── GPU ──
CUDA_VISIBLE_DEVICES=0
GPU_MAX_VRAM_PERCENT=90

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000"]

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=console                                 # console | json
